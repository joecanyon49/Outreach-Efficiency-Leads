# GCU Lead Discovery Engine Backend - API Keys
# Copy this to .env and fill in your API keys

# NewsAPI - Free tier for article/news/podcast searching
# Get free key at: https://newsapi.org (register, free tier = 100/day)
NEWSAPI_KEY=your_newsapi_key_here

# Census API - Free tier for income/demographic data
# Get free key at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_key_here

# ProPublica - No key needed, but good to know about
# Used for IRS 990 data and nonprofit giving information
# API docs: https://projects.propublica.org/nonprofits/api

# Optional: Cloudflare Workers URL for proxy (CORS bypass)
# If using Cloudflare Workers to proxy requests
CLOUDFLARE_WORKER_URL=https://your-worker.workers.dev
